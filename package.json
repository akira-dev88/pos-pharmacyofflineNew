{
  "name": "POS-Pharmacy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Complete POS billing system for retail stores",
  "author": "Your Name <your.email@example.com>",
  "scripts": {
    "backend": "cross-env APP_TYPE=pharmacy APP_DB_NAME=pharmacy.db tsx watch server/src/index.ts",
    "frontend": "vite",
    "electron": "electron electron/main.cjs",
    "dev": "concurrently -n BACK,FRONT,ELEC -c blue,green,yellow \"npm run backend\" \"npm run frontend\" \"wait-on http://localhost:5173 && wait-on http://127.0.0.1:3000/health && npm run electron\"",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "esbuild server/src/index.ts --bundle --platform=node --target=node20 --outfile=server/dist/index.cjs --external:better-sqlite3",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "predist:win": "npm run rebuild:electron",
    "predist:linux": "npm run rebuild:electron",
    "seed": "cross-env APP_TYPE=pharmacy APP_DB_NAME=pharmacy.db tsx server/src/seeds/index.ts"
  },
  "build": {
    "appId": "com.pos.pharmacy",
    "productName": "POS pharmacy",
    "asar": true,
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POS pharmacy",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "server/dist/**/*",
      "assets/icon.ico"
    ],
    "extraResources": [
      {
        "from": "server/dist",
        "to": "server"
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": "node_modules/better-sqlite3"
      },
      {
        "from": "node_modules/bindings",
        "to": "node_modules/bindings"
      },
      {
        "from": "node_modules/file-uri-to-path",
        "to": "node_modules/file-uri-to-path"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@ionic/react": "^8.8.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "esc-pos-encoder": "^3.0.0",
    "express": "^5.2.1",
    "i18next": "^26.1.0",
    "ionicons": "^8.0.13",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.7",
    "react-is": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "recharts": "^2.15.4",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.10",
    "rollup": "^4.60.2",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-tsconfig-paths": "^6.1.1",
    "wait-on": "^9.0.5"
  }
}
